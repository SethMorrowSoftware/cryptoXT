-- sodium.lcb - the LiveCode Builder binding for SodiumXT (public sx* surface).
--
-- This thin layer sits on top of the C shim (src/sodium_shim.c, ABI sxt_*) and
-- presents friendly handlers to xTalk. It now covers the full Phase 1-5 surface:
-- randomness, hashing, encoding, constant-time compare, Argon2id, secretbox,
-- AEAD, streaming AEAD + file helpers, public-key boxes, ed25519 signatures,
-- key derivation, key exchange, and padding.
--
-- ==========================================================================
-- VERIFIED ON-ENGINE. This module compiles, loads, and runs on the OXT engine
-- (Windows x64): examples/sodium-tests.livecodescript `put sxSelfTest()` reports
-- 35 / 35 PASSED, exercising every sx* handler with round trips, known-answer
-- vectors, and tamper / wrong-key checks. The conventions below were settled
-- against a real OXT compile and a crash audit; they are recorded so they are
-- not relearned:
--   * an LCB library is a bracketed block: it must end with `end library`;
--   * foreign types (Pointer/CInt/CUInt/CBool/UIntSize/ZStringUTF8) come from
--     `use com.livecode.foreign`; `&`/`&&`/`is`/`is not` from
--     `use com.livecode.string`; `+`/`-`/`*`/`<` from `use com.livecode.arithmetic`;
--   * the in-buffer accessor is MCDataGetBytePtr (not ...Byptr);
--   * textEncode/textDecode are NOT available to an LCB module, so byte values
--     cross as Data and a String is built from filled bytes with
--     MCStringCreateWithBytes (the engine's own idiom). Hex/base64 and the
--     pwhash_str output are returned as Data (ASCII bytes); textDecode in
--     livecodescript if a String is wanted;
--   * MCMemoryAllocate's size is C `size_t`, so it marshals as UIntSize, NOT
--     CUInt (a 4-byte size into an 8-byte slot on 64-bit corrupts the heap);
--   * a foreign handler must NOT RETURN a bridged C string (ZStringUTF8 etc.):
--     the engine adopts and free()s the returned pointer, so a static return is
--     a free()-on-static crash. Fill a caller buffer and return length/-needed
--     instead (the shim returns no const char*);
--   * pass a null pointer as `nothing` only through an `optional Pointer`
--     parameter (e.g. the unkeyed-hash key); a plain Pointer rejects `nothing`;
--   * out parameters are passed by reference: command form `sxBoxKeypair tPk, tSk`,
--     or inside a function call `put sxSecretStreamInitPush(tKey, tHeader) into h`.
-- The native C layer is independently tested (KATs + ASan/UBSan, 160 checks);
-- the current C ABI is SXT_ABI_VERSION 4 (kSXTABIVersion below must match).
-- ==========================================================================

library org.openxtalk.library.sodium

use com.livecode.foreign
use com.livecode.string
use com.livecode.arithmetic

metadata version    is "0.1.0"
metadata author     is "OpenXTalk"
metadata title      is "SodiumXT"
metadata summary    is "Modern cryptography for xTalk via libsodium (authenticated encryption, Argon2id, streaming AEAD, X25519, ed25519, BLAKE2b, CSPRNG)."

-- Mirror the C side; keep these in step with src/sodium_shim.h.
--   kSXTABIVersion == SXT_ABI_VERSION ; kSXTErrBase == SXT_ERR_BASE.
-- Declared before first use (OXT resolves a constant by lexical position; a
-- forward reference silently evaluates to nothing).
constant kSXTABIVersion is 4
constant kSXTErrBase is -2000000000

-- The engine MCStringEncoding enum value for UTF-8 (libfoundation: ASCII=0,
-- Windows1252=1, MacRoman=2, ISO8859_1=3, UTF8=4, ...). Used when building a
-- String from bytes the shim filled (see sToString). Our shim strings are ASCII
-- (a UTF-8 subset), so this round-trips them exactly.
constant kMCStringEncodingUTF8 is 4

-- --------------------------------------------------------------------------
-- Engine memory + Data bridges (resolve by NAME, so NO leading underscore).
-- An LCB Data does not auto-bridge to a void*, so an out buffer is a raw block
-- from MCMemoryAllocate passed as a Pointer, an in buffer is MCDataGetBytePtr +
-- MCDataGetLength, and written bytes are copied back with MCDataCreateWithBytes.
-- --------------------------------------------------------------------------
-- MCMemoryAllocate's size is C `size_t`, so it MUST marshal as UIntSize (the
-- LCB size type). Declaring it CUInt passes a 4-byte int where the callee reads
-- an 8-byte size_t on a 64-bit build: the high word is garbage, the allocation
-- size is wrong, and the first sxRandomBytes/hash/etc. corrupts memory. UIntSize
-- is what the proven htmltidy and TorrentXT bindings use here.
foreign handler MCMemoryAllocate(in pSize as UIntSize, out rPtr as Pointer) returns CBool binds to "<builtin>"
foreign handler MCMemoryDeallocate(in pPtr as Pointer) returns nothing binds to "<builtin>"
foreign handler MCDataGetBytePtr(in pData as Data) returns Pointer binds to "<builtin>"
foreign handler MCDataGetLength(in pData as Data) returns CUInt binds to "<builtin>"
foreign handler MCDataCreateWithBytes(in pBytes as Pointer, in pLen as CUInt, out rData as Data) returns CBool binds to "<builtin>"
-- Build a String from bytes the shim filled (used by the string-returning calls
-- below). pEncoding is kMCStringEncodingUTF8; pIsExternalRep is false. This is
-- the engine's own bytes -> String idiom (libscript module-foreign UTF8 import).
foreign handler MCStringCreateWithBytes(in pBytes as Pointer, in pByteCount as CUInt, in pEncoding as CUInt, in pIsExternalRep as CBool, out rString as String) returns CBool binds to "<builtin>"

-- --------------------------------------------------------------------------
-- The SodiumXT C ABI. Private _sxt_* names; the bind strings reference the
-- stable exported symbols by name.
-- --------------------------------------------------------------------------
-- The string-returning entry points FILL a caller buffer and return the length
-- (or -needed); they do NOT return a C string. A foreign handler that returns a
-- bridged C string (ZStringUTF8 / NativeCString / WString) makes the engine
-- ADOPT and later free() the returned pointer, so returning the shim's static
-- version/error/memlimit strings would be free()-on-static: heap corruption on
-- the very first call (this is what crashed the harness at sxVersion). So these
-- mirror the byte-buffer calls: out Pointer + capacity in, length/-needed out.
foreign handler _sxt_init() returns CInt binds to "c:sodiumxt>sxt_init"
foreign handler _sxt_version(in pOut as Pointer, in pCap as CInt) returns CInt binds to "c:sodiumxt>sxt_version"
foreign handler _sxt_sodium_version(in pOut as Pointer, in pCap as CInt) returns CInt binds to "c:sodiumxt>sxt_sodium_version"
foreign handler _sxt_abi_version() returns CInt binds to "c:sodiumxt>sxt_abi_version"
foreign handler _sxt_last_error(in pOut as Pointer, in pCap as CInt) returns CInt binds to "c:sodiumxt>sxt_last_error"
foreign handler _sxt_randombytes(in pOut as Pointer, in pCap as CInt, in pCount as CInt) returns CInt binds to "c:sodiumxt>sxt_randombytes"

-- pKey is `optional Pointer` so the unkeyed hash can pass `nothing` as a C NULL:
-- a plain `Pointer` parameter rejects `nothing` ("not of correct type"), and
-- `optional` is the LCB-sanctioned way to marshal a null pointer. The C side
-- treats key==NULL with keylen==0 as unkeyed (BLAKE2b), so the ABI is unchanged.
foreign handler _sxt_generichash(in pOut as Pointer, in pCap as CInt, in pOutLen as CInt, in pIn as Pointer, in pInLen as CInt, in pKey as optional Pointer, in pKeyLen as CInt) returns CInt binds to "c:sodiumxt>sxt_generichash"
foreign handler _sxt_bin2hex(in pOut as Pointer, in pCap as CInt, in pIn as Pointer, in pInLen as CInt) returns CInt binds to "c:sodiumxt>sxt_bin2hex"
foreign handler _sxt_hex2bin(in pOut as Pointer, in pCap as CInt, in pHex as Pointer, in pHexLen as CInt) returns CInt binds to "c:sodiumxt>sxt_hex2bin"
foreign handler _sxt_bin2base64(in pOut as Pointer, in pCap as CInt, in pIn as Pointer, in pInLen as CInt, in pVariant as CInt) returns CInt binds to "c:sodiumxt>sxt_bin2base64"
foreign handler _sxt_base642bin(in pOut as Pointer, in pCap as CInt, in pB64 as Pointer, in pB64Len as CInt, in pVariant as CInt) returns CInt binds to "c:sodiumxt>sxt_base642bin"
foreign handler _sxt_base64_variant_urlsafe_no_padding() returns CInt binds to "c:sodiumxt>sxt_base64_variant_urlsafe_no_padding"
foreign handler _sxt_memequal(in pA as Pointer, in pALen as CInt, in pB as Pointer, in pBLen as CInt) returns CInt binds to "c:sodiumxt>sxt_memequal"

foreign handler _sxt_secretbox(in pOut as Pointer, in pCap as CInt, in pMsg as Pointer, in pMsgLen as CInt, in pKey as Pointer, in pKeyLen as CInt) returns CInt binds to "c:sodiumxt>sxt_secretbox"
foreign handler _sxt_secretbox_open(in pOut as Pointer, in pCap as CInt, in pBox as Pointer, in pBoxLen as CInt, in pKey as Pointer, in pKeyLen as CInt) returns CInt binds to "c:sodiumxt>sxt_secretbox_open"
foreign handler _sxt_aead_encrypt(in pOut as Pointer, in pCap as CInt, in pMsg as Pointer, in pMsgLen as CInt, in pAd as Pointer, in pAdLen as CInt, in pKey as Pointer, in pKeyLen as CInt) returns CInt binds to "c:sodiumxt>sxt_aead_encrypt"
foreign handler _sxt_aead_decrypt(in pOut as Pointer, in pCap as CInt, in pBox as Pointer, in pBoxLen as CInt, in pAd as Pointer, in pAdLen as CInt, in pKey as Pointer, in pKeyLen as CInt) returns CInt binds to "c:sodiumxt>sxt_aead_decrypt"

foreign handler _sxt_pwhash(in pOut as Pointer, in pCap as CInt, in pOutLen as CInt, in pPass as Pointer, in pPassLen as CInt, in pSalt as Pointer, in pSaltLen as CInt, in pOps as ZStringUTF8, in pMem as ZStringUTF8) returns CInt binds to "c:sodiumxt>sxt_pwhash"
foreign handler _sxt_pwhash_str(in pOut as Pointer, in pCap as CInt, in pPass as Pointer, in pPassLen as CInt, in pOps as ZStringUTF8, in pMem as ZStringUTF8) returns CInt binds to "c:sodiumxt>sxt_pwhash_str"
foreign handler _sxt_pwhash_str_verify(in pHash as ZStringUTF8, in pPass as Pointer, in pPassLen as CInt) returns CInt binds to "c:sodiumxt>sxt_pwhash_str_verify"
foreign handler _sxt_pwhash_saltbytes() returns CInt binds to "c:sodiumxt>sxt_pwhash_saltbytes"
foreign handler _sxt_pwhash_strbytes() returns CInt binds to "c:sodiumxt>sxt_pwhash_strbytes"
foreign handler _sxt_pwhash_opslimit_interactive() returns CInt binds to "c:sodiumxt>sxt_pwhash_opslimit_interactive"
foreign handler _sxt_pwhash_opslimit_moderate() returns CInt binds to "c:sodiumxt>sxt_pwhash_opslimit_moderate"
foreign handler _sxt_pwhash_opslimit_sensitive() returns CInt binds to "c:sodiumxt>sxt_pwhash_opslimit_sensitive"
foreign handler _sxt_pwhash_memlimit_interactive(in pOut as Pointer, in pCap as CInt) returns CInt binds to "c:sodiumxt>sxt_pwhash_memlimit_interactive"
foreign handler _sxt_pwhash_memlimit_moderate(in pOut as Pointer, in pCap as CInt) returns CInt binds to "c:sodiumxt>sxt_pwhash_memlimit_moderate"
foreign handler _sxt_pwhash_memlimit_sensitive(in pOut as Pointer, in pCap as CInt) returns CInt binds to "c:sodiumxt>sxt_pwhash_memlimit_sensitive"
foreign handler _sxt_kdf_derive(in pOut as Pointer, in pCap as CInt, in pSubLen as CInt, in pId as ZStringUTF8, in pCtx as Pointer, in pCtxLen as CInt, in pMaster as Pointer, in pMasterLen as CInt) returns CInt binds to "c:sodiumxt>sxt_kdf_derive"

foreign handler _sxt_secretstream_headerbytes() returns CInt binds to "c:sodiumxt>sxt_secretstream_headerbytes"
foreign handler _sxt_secretstream_tag_message() returns CInt binds to "c:sodiumxt>sxt_secretstream_tag_message"
foreign handler _sxt_secretstream_tag_final() returns CInt binds to "c:sodiumxt>sxt_secretstream_tag_final"
foreign handler _sxt_secretstream_init_push(in pHeader as Pointer, in pHeaderCap as CInt, in pKey as Pointer, in pKeyLen as CInt) returns CInt binds to "c:sodiumxt>sxt_secretstream_init_push"
foreign handler _sxt_secretstream_push(in pHandle as CInt, in pOut as Pointer, in pCap as CInt, in pChunk as Pointer, in pChunkLen as CInt, in pAd as Pointer, in pAdLen as CInt, in pTag as CInt) returns CInt binds to "c:sodiumxt>sxt_secretstream_push"
foreign handler _sxt_secretstream_init_pull(in pHeader as Pointer, in pHeaderLen as CInt, in pKey as Pointer, in pKeyLen as CInt) returns CInt binds to "c:sodiumxt>sxt_secretstream_init_pull"
foreign handler _sxt_secretstream_pull(in pHandle as CInt, in pOut as Pointer, in pCap as CInt, in pIn as Pointer, in pInLen as CInt, in pAd as Pointer, in pAdLen as CInt) returns CInt binds to "c:sodiumxt>sxt_secretstream_pull"
foreign handler _sxt_secretstream_last_tag(in pHandle as CInt) returns CInt binds to "c:sodiumxt>sxt_secretstream_last_tag"
foreign handler _sxt_free_stream(in pHandle as CInt) returns nothing binds to "c:sodiumxt>sxt_free_stream"
foreign handler _sxt_encrypt_file(in pSrc as ZStringUTF8, in pDst as ZStringUTF8, in pKey as Pointer, in pKeyLen as CInt) returns CInt binds to "c:sodiumxt>sxt_encrypt_file"
foreign handler _sxt_decrypt_file(in pSrc as ZStringUTF8, in pDst as ZStringUTF8, in pKey as Pointer, in pKeyLen as CInt) returns CInt binds to "c:sodiumxt>sxt_decrypt_file"

foreign handler _sxt_box_publickeybytes() returns CInt binds to "c:sodiumxt>sxt_box_publickeybytes"
foreign handler _sxt_box_secretkeybytes() returns CInt binds to "c:sodiumxt>sxt_box_secretkeybytes"
foreign handler _sxt_box_keypair(in pPk as Pointer, in pPkCap as CInt, in pSk as Pointer, in pSkCap as CInt) returns CInt binds to "c:sodiumxt>sxt_box_keypair"
foreign handler _sxt_box(in pOut as Pointer, in pCap as CInt, in pMsg as Pointer, in pMsgLen as CInt, in pRpk as Pointer, in pRpkLen as CInt, in pSsk as Pointer, in pSskLen as CInt) returns CInt binds to "c:sodiumxt>sxt_box"
foreign handler _sxt_box_open(in pOut as Pointer, in pCap as CInt, in pBox as Pointer, in pBoxLen as CInt, in pSpk as Pointer, in pSpkLen as CInt, in pRsk as Pointer, in pRskLen as CInt) returns CInt binds to "c:sodiumxt>sxt_box_open"
foreign handler _sxt_box_seal(in pOut as Pointer, in pCap as CInt, in pMsg as Pointer, in pMsgLen as CInt, in pRpk as Pointer, in pRpkLen as CInt) returns CInt binds to "c:sodiumxt>sxt_box_seal"
foreign handler _sxt_box_seal_open(in pOut as Pointer, in pCap as CInt, in pSealed as Pointer, in pSealedLen as CInt, in pRpk as Pointer, in pRpkLen as CInt, in pRsk as Pointer, in pRskLen as CInt) returns CInt binds to "c:sodiumxt>sxt_box_seal_open"

foreign handler _sxt_sign_publickeybytes() returns CInt binds to "c:sodiumxt>sxt_sign_publickeybytes"
foreign handler _sxt_sign_secretkeybytes() returns CInt binds to "c:sodiumxt>sxt_sign_secretkeybytes"
foreign handler _sxt_sign_bytes() returns CInt binds to "c:sodiumxt>sxt_sign_bytes"
foreign handler _sxt_sign_seedbytes() returns CInt binds to "c:sodiumxt>sxt_sign_seedbytes"
foreign handler _sxt_sign_keypair(in pPk as Pointer, in pPkCap as CInt, in pSk as Pointer, in pSkCap as CInt) returns CInt binds to "c:sodiumxt>sxt_sign_keypair"
foreign handler _sxt_sign_keypair_from_seed(in pPk as Pointer, in pPkCap as CInt, in pSk as Pointer, in pSkCap as CInt, in pSeed as Pointer, in pSeedLen as CInt) returns CInt binds to "c:sodiumxt>sxt_sign_keypair_from_seed"
foreign handler _sxt_sign_detached(in pSig as Pointer, in pSigCap as CInt, in pMsg as Pointer, in pMsgLen as CInt, in pSk as Pointer, in pSkLen as CInt) returns CInt binds to "c:sodiumxt>sxt_sign_detached"
foreign handler _sxt_sign_verify_detached(in pSig as Pointer, in pSigLen as CInt, in pMsg as Pointer, in pMsgLen as CInt, in pPk as Pointer, in pPkLen as CInt) returns CInt binds to "c:sodiumxt>sxt_sign_verify_detached"
foreign handler _sxt_sign(in pOut as Pointer, in pCap as CInt, in pMsg as Pointer, in pMsgLen as CInt, in pSk as Pointer, in pSkLen as CInt) returns CInt binds to "c:sodiumxt>sxt_sign"
foreign handler _sxt_sign_open(in pOut as Pointer, in pCap as CInt, in pSigned as Pointer, in pSignedLen as CInt, in pPk as Pointer, in pPkLen as CInt) returns CInt binds to "c:sodiumxt>sxt_sign_open"

foreign handler _sxt_kx_publickeybytes() returns CInt binds to "c:sodiumxt>sxt_kx_publickeybytes"
foreign handler _sxt_kx_secretkeybytes() returns CInt binds to "c:sodiumxt>sxt_kx_secretkeybytes"
